# ========================================
# PLANTILLA DE VARIABLES DE ENTORNO LOCALES
# ========================================
# 
# Este archivo es una PLANTILLA OPCIONAL para desarrollo local.
# 
# Instrucciones:
# 1. Copia este archivo como `.env.local` (ya está en .gitignore)
# 2. Descomenta las variables que necesites personalizar
# 3. Ajusta los valores según tu entorno local
#
# IMPORTANTE: 
# - NO commitees `.env.local` al repositorio
# - NO es necesario en producción (Azure Static Web Apps)
# - La aplicación funciona sin este archivo

# ============================================
# OPTIMIZACIONES DE RENDIMIENTO (OPCIONALES)
# ============================================

# Desactivar source maps para compilar más rápido (recomendado)
# Comenta esta línea si necesitas debuggear con breakpoints en el navegador
# VITE_SOURCEMAP=false

# API Base URL personalizada (normalmente NO necesario)
# Por defecto, usa detección automática:
#   - localhost:5173 → https://localhost:7152
#   - producción → mismo dominio del frontend
# Solo descomenta si tu backend local está en otro puerto/host:
# VITE_API_BASE_URL=https://localhost:8080

# Desactivar telemetría de herramientas de desarrollo
# VITE_DISABLE_TELEMETRY=true

# ============================================
# SERVICIOS EXTERNOS (SI LOS USAS EN EL FUTURO)
# ============================================

# AWS Cognito (actualmente no usado)
# VITE_AWS_PROJECT_REGION=us-east-1
# VITE_AWS_COGNITO_IDENTITY_POOL_ID=
# VITE_AWS_USER_POOLS_ID=
# VITE_AWS_USER_POOLS_WEB_CLIENT_ID=
# VITE_AWS_OAUTH_DOMAIN=
# VITE_AWS_OAUTH_REDIRECT_SIGN_IN=
# VITE_AWS_OAUTH_REDIRECT_SIGN_OUT=

# Firebase (actualmente no usado)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
